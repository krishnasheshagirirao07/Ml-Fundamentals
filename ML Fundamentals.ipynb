        "print(\"Shape of the data:\", iris_data.shape)\n",
        "\n",
        "\n",
        "x = iris_data[:, 0]\n",
        "y = iris_data[:, 2]\n",
        "\n",
        "\n",
        "plt.scatter(x, y)\n",
        "\n",
        "\n",
        "plt.title(\"Iris Dataset: Sepal Length vs Petal Length\")\n",
        "plt.xlabel(\"Sepal Length (cm)\")\n",
        "plt.ylabel(\"Petal Length (cm)\")\n",
        "\n",
        "\n",
        "plt.show()\n"
